@model GoalZone.API.DTOs.AdminDTOs.MatchCreatePageDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>GoalZone Admin - Yeni Maç Ekle</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<style>
:root{
  --bg:#080d18;--bg2:#0c1220;--card:#111827;--card2:#16202f;--elevated:#1c2d42;
  --green:#00e676;--blue:#2979ff;--live:#ff1744;--gold:#ffd600;--yellow:#ffc107;--red:#f44336;
  --t1:#eef2ff;--t2:#7b96c4;--t3:#3d5478;--border:#1a2640;
  --r1:8px;--r2:12px;--r3:16px;
  --tr:all .22s cubic-bezier(.4,0,.2,1);
  --fd:'Barlow Condensed',sans-serif;--fb:'Barlow',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--fb);background:var(--bg);color:var(--t1);min-height:100vh;
  background-image:
    radial-gradient(ellipse at 15% 0%,rgba(41,121,255,.07) 0%,transparent 55%),
    radial-gradient(ellipse at 85% 0%,rgba(0,230,118,.04) 0%,transparent 50%)}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--elevated);border-radius:3px}
a{text-decoration:none;color:inherit}
.nb{background:rgba(8,13,24,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:1000;box-shadow:0 2px 24px rgba(0,0,0,.5)}
.nb-inner{max-width:1120px;margin:0 auto;padding:0 20px;
  display:flex;align-items:center;justify-content:space-between;gap:16px}
.brand{display:flex;align-items:center;gap:10px;padding:14px 0}
.brand-ico{width:34px;height:34px;background:linear-gradient(135deg,var(--green),var(--blue));
  border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:17px;color:#fff}
.brand-txt{font-family:var(--fd);font-size:21px;font-weight:800;letter-spacing:1px}
.brand-txt span{color:var(--green)}
.nav-links{display:flex}
.nl{font-family:var(--fd);font-size:14px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  color:var(--t2);padding:22px 15px;position:relative;transition:var(--tr)}
.nl::after{content:'';position:absolute;bottom:0;left:15px;right:15px;height:2px;
  background:var(--blue);transform:scaleX(0);transition:var(--tr)}
.nl:hover,.nl.active{color:var(--t1)}.nl:hover::after,.nl.active::after{transform:scaleX(1)}
.wrap{max-width:1120px;margin:0 auto;padding:40px 20px}
.page-title{font-family:var(--fd);font-size:32px;font-weight:800;letter-spacing:1px;margin-bottom:8px}
.page-subtitle{color:var(--t2);font-size:14px;margin-bottom:30px}
.admin-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:30px;box-shadow:0 10px 30px rgba(0,0,0,.5)}
.form-label{font-family:var(--fd);font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--t2);margin-bottom:6px}
.form-control,.form-select{background:var(--bg2);border:1px solid var(--border);color:var(--t1);border-radius:var(--r1);padding:12px 16px;font-size:15px;transition:var(--tr)}
.form-control:focus,.form-select:focus{background:var(--card2);border-color:var(--blue);box-shadow:0 0 0 3px rgba(41,121,255,.15);color:var(--t1)}
.form-control::placeholder{color:var(--t3)}
.form-check-input{background-color:var(--bg2);border-color:var(--border);width:20px;height:20px;margin-top:2px}
.form-check-input:checked{background-color:var(--green);border-color:var(--green)}
.btn-primary{background:linear-gradient(135deg,var(--green),var(--blue));border:none;font-family:var(--fd);font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:14px 30px;border-radius:var(--r1);font-size:16px;transition:var(--tr)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(41,121,255,.3)}
.section-head{display:flex;align-items:center;gap:12px;font-family:var(--fd);font-size:18px;font-weight:700;color:var(--t1);text-transform:uppercase;letter-spacing:1px;margin-top:24px;margin-bottom:20px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.section-head i{color:var(--blue)}
.field-validation-error{display:block;color:#ff9fb0;font-size:12px;margin-top:6px}
.validation-summary-errors{margin-bottom:18px}
.validation-summary-errors ul{padding-left:18px;margin-bottom:0;color:#ff9fb0}
.text-input{color:var(--t1)}
.empty-state{border:1px dashed var(--border);border-radius:var(--r1);padding:14px 16px;color:var(--t2);font-size:14px;background:rgba(255,255,255,.02)}
</style>
</head>
<body>
<nav class="nb">
  <div class="nb-inner">
    <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="brand">
      <div class="brand-ico"><i class="bi bi-shield-lock-fill"></i></div>
      <span class="brand-txt">GoalZone <span>Admin</span></span>
    </a>
    <div class="nav-links d-none d-lg-flex">
      <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="nl active">Maç Ekle</a>
      <a asp-area="Admin" asp-controller="Match" asp-action="EventCreate" class="nl">Olay Ekle</a>
      <a asp-area="Admin" asp-controller="Match" asp-action="StatisticCreate" class="nl">İstatistik Ekle</a>
    </div>
  </div>
</nav>

<div class="wrap">
  <h1 class="page-title">YENİ MAÇ EKLE</h1>
  <p class="page-subtitle">Sisteme yeni bir müsabaka kaydı ve temel detaylarını ekleyin.</p>

  @if (TempData["SuccessMessage"] is string successMessage)
  {
      <div class="alert alert-success mb-4">@successMessage</div>
  }

  <div class="admin-card">
    <form asp-area="Admin" asp-controller="Match" asp-action="Create" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

      <div class="section-head"><i class="bi bi-calendar3"></i> Genel Bilgiler</div>
      <div class="row g-4">
        <div class="col-md-4">
          <label asp-for="Form.SeasonId" class="form-label">Sezon</label>
          <select asp-for="Form.SeasonId" class="form-select">
            <option value="">-- Sezon Seçin --</option>
            @foreach (var season in Model.Seasons)
            {
                <option value="@season.Id">@season.Name</option>
            }
          </select>
          <span asp-validation-for="Form.SeasonId"></span>
        </div>
        <div class="col-md-4">
          <label asp-for="Form.WeekNumber" class="form-label">Hafta</label>
          <input asp-for="Form.WeekNumber" class="form-control" placeholder="Örn: 33" min="1" max="40" />
          <span asp-validation-for="Form.WeekNumber"></span>
        </div>
        <div class="col-md-4">
          <label asp-for="Form.MatchDate" class="form-label">Maç Tarihi</label>
          <input asp-for="Form.MatchDate" class="form-control" type="datetime-local" value="@Model.Form.MatchDate.ToString("yyyy-MM-ddTHH:mm")" />
          <span asp-validation-for="Form.MatchDate"></span>
        </div>
      </div>

      <div class="section-head"><i class="bi bi-people-fill"></i> Takımlar</div>
      @if (Model.Teams.Any())
      {
          <div class="row g-4">
            <div class="col-md-6">
              <label asp-for="Form.HomeTeamId" class="form-label">Ev Sahibi Takım</label>
              <select asp-for="Form.HomeTeamId" class="form-select">
                <option value="">-- Takım Seçin --</option>
                @foreach (var team in Model.Teams)
                {
                    <option value="@team.Id">@team.Name</option>
                }
              </select>
              <span asp-validation-for="Form.HomeTeamId"></span>
            </div>
            <div class="col-md-6">
              <label asp-for="Form.AwayTeamId" class="form-label">Deplasman Takım</label>
              <select asp-for="Form.AwayTeamId" class="form-select">
                <option value="">-- Takım Seçin --</option>
                @foreach (var team in Model.Teams)
                {
                    <option value="@team.Id">@team.Name</option>
                }
              </select>
              <span asp-validation-for="Form.AwayTeamId"></span>
            </div>
          </div>
      }
      else
      {
          <div class="empty-state">Takım verisi bulunamadı. Önce takım kayıtlarının sistemde yer aldığından emin olun.</div>
      }

      <div class="section-head"><i class="bi bi-geo-alt-fill"></i> Lokasyon ve Durum</div>
      <div class="row g-4">
        <div class="col-md-6">
          <label asp-for="Form.StadiumName" class="form-label">Stadyum Adı</label>
          <input asp-for="Form.StadiumName" class="form-control" placeholder="Örn: Emirates Stadium" />
          <span asp-validation-for="Form.StadiumName"></span>
        </div>
        <div class="col-md-3">
          <label asp-for="Form.Status" class="form-label">Maç Durumu</label>
          <select asp-for="Form.Status" class="form-select">
            @foreach (var status in Model.Statuses)
            {
                <option value="@status.Id">@status.Name</option>
            }
          </select>
          <span asp-validation-for="Form.Status"></span>
        </div>
        <div class="col-md-3 d-flex align-items-center mt-auto mb-2">
          <div class="form-check pt-2">
            <input asp-for="Form.IsFeaturedMatch" class="form-check-input" />
            <label asp-for="Form.IsFeaturedMatch" class="form-check-label ms-2 text-warning fw-bold" style="font-family:var(--fd);letter-spacing:1px;">
              ÖNE ÇIKAN MAÇ YAP
            </label>
          </div>
        </div>
      </div>

      <div class="section-head"><i class="bi bi-123"></i> Skor Durumu</div>
      <div class="row g-4">
        <div class="col-md-3">
          <label asp-for="Form.HomeHalfTimeScore" class="form-label">Ev İY Skor</label>
          <input asp-for="Form.HomeHalfTimeScore" class="form-control" min="0" />
          <span asp-validation-for="Form.HomeHalfTimeScore"></span>
        </div>
        <div class="col-md-3">
          <label asp-for="Form.AwayHalfTimeScore" class="form-label">Dep İY Skor</label>
          <input asp-for="Form.AwayHalfTimeScore" class="form-control" min="0" />
          <span asp-validation-for="Form.AwayHalfTimeScore"></span>
        </div>
        <div class="col-md-3">
          <label asp-for="Form.HomeFullTimeScore" class="form-label">Ev MS Skor</label>
          <input asp-for="Form.HomeFullTimeScore" class="form-control" min="0" />
          <span asp-validation-for="Form.HomeFullTimeScore"></span>
        </div>
        <div class="col-md-3">
          <label asp-for="Form.AwayFullTimeScore" class="form-label">Dep MS Skor</label>
          <input asp-for="Form.AwayFullTimeScore" class="form-control" min="0" />
          <span asp-validation-for="Form.AwayFullTimeScore"></span>
        </div>
      </div>

      <div class="d-flex justify-content-end mt-5">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle me-2"></i> Maçı Kaydet</button>
      </div>
    </form>
  </div>
</div>

<partial name="_ValidationScriptsPartial" />
</body>
</html>

@model GoalZone.API.DTOs.AdminDTOs.EventCreatePageDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>GoalZone Admin - Yeni Olay Ekle</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#080d18;--bg2:#0c1220;--card:#111827;--card2:#16202f;--elevated:#1c2d42;
  --green:#00e676;--blue:#2979ff;--live:#ff1744;--gold:#ffd600;--yellow:#ffc107;--red:#f44336;
  --t1:#eef2ff;--t2:#7b96c4;--t3:#3d5478;--border:#1a2640;
  --r1:8px;--r2:12px;--r3:16px;
  --tr:all .22s cubic-bezier(.4,0,.2,1);
  --fd:'Barlow Condensed',sans-serif;--fb:'Barlow',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--fb);background:var(--bg);color:var(--t1);min-height:100vh;
  background-image:
    radial-gradient(ellipse at 15% 0%,rgba(41,121,255,.07) 0%,transparent 55%),
    radial-gradient(ellipse at 85% 0%,rgba(0,230,118,.04) 0%,transparent 50%)}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--elevated);border-radius:3px}
a{text-decoration:none;color:inherit}
.nb{background:rgba(8,13,24,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:1000;box-shadow:0 2px 24px rgba(0,0,0,.5)}
.nb-inner{max-width:1120px;margin:0 auto;padding:0 20px;
  display:flex;align-items:center;justify-content:space-between;gap:16px}
.brand{display:flex;align-items:center;gap:10px;padding:14px 0}
.brand-ico{width:34px;height:34px;background:linear-gradient(135deg,var(--green),var(--blue));
  border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:17px; color: #fff;}
.brand-txt{font-family:var(--fd);font-size:21px;font-weight:800;letter-spacing:1px}
.brand-txt span{color:var(--green)}
.nav-links{display:flex}
.nl{font-family:var(--fd);font-size:14px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  color:var(--t2);padding:22px 15px;position:relative;transition:var(--tr)}
.nl::after{content:'';position:absolute;bottom:0;left:15px;right:15px;height:2px;
  background:var(--blue);transform:scaleX(0);transition:var(--tr)}
.nl:hover,.nl.active{color:var(--t1)}.nl:hover::after,.nl.active::after{transform:scaleX(1)}
.wrap{max-width:1120px;margin:0 auto;padding:40px 20px}
.page-title{font-family:var(--fd);font-size:32px;font-weight:800;letter-spacing:1px;margin-bottom:8px;}
.page-subtitle{color:var(--t2);font-size:14px;margin-bottom:30px;}
.admin-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r2);
  padding: 30px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}
.form-label {
  font-family: var(--fd);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--t2);
  margin-bottom: 6px;
}
.form-control, .form-select {
  background: var(--bg2);
  border: 1px solid var(--border);
  color: var(--t1);
  border-radius: var(--r1);
  padding: 12px 16px;
  font-size: 15px;
  transition: var(--tr);
}
.form-control:focus, .form-select:focus {
  background: var(--card2);
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(41,121,255,0.15);
  color: var(--t1);
}
.form-control::placeholder {
  color: var(--t3);
}
.btn-primary {
  background: linear-gradient(135deg, var(--green), var(--blue));
  border: none;
  font-family: var(--fd);
  font-weight: 800;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 14px 30px;
  border-radius: var(--r1);
  font-size: 16px;
  transition: var(--tr);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(41,121,255,0.3);
}
.section-head {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--fd);
  font-size: 18px;
  font-weight: 700;
  color: var(--t1);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 24px;
  margin-bottom: 20px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.section-head i {
  color: var(--blue);
}
.event-option {
  display: flex;
  align-items: center;
  gap: 8px;
}
.dot {
  display: inline-block;
  width: 12px;
  height: 12px;
  border-radius: 50%;
}
.dot.goal { background-color: var(--green); }
.dot.yellow { background-color: var(--yellow); }
.dot.red { background-color: var(--red); }
.field-validation-error{display:block;color:#ff9fb0;font-size:12px;margin-top:6px}
.validation-summary-errors{margin-bottom:18px}
.validation-summary-errors ul{padding-left:18px;margin-bottom:0;color:#ff9fb0}
</style>
</head>
<body>

<nav class="nb">
  <div class="nb-inner">
    <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="brand">
      <div class="brand-ico"><i class="bi bi-shield-lock-fill"></i></div>
      <span class="brand-txt">GoalZone <span>Admin</span></span>
    </a>
    <div class="nav-links d-none d-lg-flex">
      <a asp-area="Admin" asp-controller="Match" asp-action="Create" class="nl">Maç Ekle</a>
      <a asp-area="Admin" asp-controller="Match" asp-action="EventCreate" class="nl active">Olay Ekle</a>
      <a asp-area="Admin" asp-controller="Match" asp-action="StatisticCreate" class="nl">İstatistik Ekle</a>
    </div>
  </div>
</nav>

<div class="wrap">
  <h1 class="page-title">YENİ MAÇ OLAYI EKLE</h1>
  <p class="page-subtitle">Seçili maç için yeni etkinlik/olay (Gol, Kart vb.) tanımlayın.</p>

  @if (TempData["SuccessMessage"] is string successMessage)
  {
      <div class="alert alert-success mb-4">@successMessage</div>
  }

  <div class="admin-card">
    <form asp-area="Admin" asp-controller="Match" asp-action="EventCreate" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
      
      <div class="section-head"><i class="bi bi-lightning-charge-fill"></i> Olay Detayları</div>
      
      <div class="row g-4">
        <div class="col-md-6">
          <label asp-for="Form.MatchId" class="form-label">Maç Seçimi (MatchId)</label>
          <select asp-for="Form.MatchId" class="form-select" id="matchSelect">
            <option value="">-- Maç Seçin --</option>
            @foreach (var match in Model.Matches)
            {
                <option value="@match.Id" data-home-team-id="@match.HomeTeamId" data-away-team-id="@match.AwayTeamId">@match.Name</option>
            }
          </select>
          <span asp-validation-for="Form.MatchId"></span>
        </div>
        
        <div class="col-md-6">
          <label asp-for="Form.TeamId" class="form-label">Takım Seçimi (TeamId)</label>
          <select asp-for="Form.TeamId" class="form-select" id="teamSelect">
            <option value="">-- Takım Seçin --</option>
            @foreach (var team in Model.Teams)
            {
                <option value="@team.Id">@team.Name</option>
            }
          </select>
          <span asp-validation-for="Form.TeamId"></span>
        </div>
      </div>

      <div class="row g-4 mt-2">
        <div class="col-md-4">
          <label asp-for="Form.PlayerId" class="form-label">Oyuncu (PlayerId)</label>
          <select asp-for="Form.PlayerId" class="form-select" id="playerSelect">
            <option value="">-- Oyuncu Seçin --</option>
            @foreach (var player in Model.Players)
            {
                <option value="@player.Id" data-team-id="@player.TeamId">@player.Name</option>
            }
          </select>
          <span asp-validation-for="Form.PlayerId"></span>
        </div>
        
        <div class="col-md-4">
          <label asp-for="Form.EventType" class="form-label">Olay Türü (EventType)</label>
          <select asp-for="Form.EventType" class="form-select">
            @foreach (var eventType in Model.EventTypes)
            {
                <option value="@eventType.Id">@eventType.Name (@eventType.Id)</option>
            }
          </select>
          <span asp-validation-for="Form.EventType"></span>
        </div>
        
        <div class="col-md-4">
          <label asp-for="Form.Minute" class="form-label">Dakika (Minute)</label>
          <input asp-for="Form.Minute" class="form-control" placeholder="Örn: 45" min="1" max="130">
          <span asp-validation-for="Form.Minute"></span>
        </div>
      </div>

      <div class="row g-4 mt-2">
        <div class="col-12">
          <label asp-for="Form.Description" class="form-label">Ek Açıklama (Description - Opsiyonel)</label>
          <textarea asp-for="Form.Description" class="form-control" rows="3" placeholder="Olay hakkında detaylı açıklama (Asist: ..., VAR kararı vs.)"></textarea>
          <span asp-validation-for="Form.Description"></span>
        </div>
      </div>

      <div class="d-flex justify-content-end mt-5">
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i> Olayı Kaydet</button>
      </div>
    </form>

    <form asp-area="Admin" asp-controller="Match" asp-action="SubstitutionCreate" method="post">
      @Html.AntiForgeryToken()

      <div class="section-head mt-5"><i class="bi bi-arrow-left-right"></i> Oyuncu Değişikliği</div>

      <div class="row g-4">
        <div class="col-md-6">
          <label asp-for="SubstitutionForm.MatchId" class="form-label">Maç Seçimi (MatchId)</label>
          <select asp-for="SubstitutionForm.MatchId" class="form-select" id="substitutionMatchSelect">
            <option value="">-- Maç Seçin --</option>
            @foreach (var match in Model.Matches)
            {
                <option value="@match.Id" data-home-team-id="@match.HomeTeamId" data-away-team-id="@match.AwayTeamId">@match.Name</option>
            }
          </select>
          <span asp-validation-for="SubstitutionForm.MatchId"></span>
        </div>

        <div class="col-md-6">
          <label asp-for="SubstitutionForm.TeamId" class="form-label">Takım Seçimi (TeamId)</label>
          <select asp-for="SubstitutionForm.TeamId" class="form-select" id="substitutionTeamSelect">
            <option value="">-- Takım Seçin --</option>
            @foreach (var team in Model.Teams)
            {
                <option value="@team.Id">@team.Name</option>
            }
          </select>
          <span asp-validation-for="SubstitutionForm.TeamId"></span>
        </div>
      </div>

      <div class="row g-4 mt-2">
        <div class="col-md-4">
          <label asp-for="SubstitutionForm.PlayerOutId" class="form-label">Çıkacak Oyuncu (PlayerOutId)</label>
          <select asp-for="SubstitutionForm.PlayerOutId" class="form-select" id="playerOutSelect">
            <option value="">-- Oyuncu Seçin --</option>
            @foreach (var player in Model.Players)
            {
                <option value="@player.Id" data-team-id="@player.TeamId">@player.Name</option>
            }
          </select>
          <span asp-validation-for="SubstitutionForm.PlayerOutId"></span>
        </div>

        <div class="col-md-4">
          <label asp-for="SubstitutionForm.PlayerInId" class="form-label">Girecek Oyuncu (PlayerInId)</label>
          <select asp-for="SubstitutionForm.PlayerInId" class="form-select" id="playerInSelect">
            <option value="">-- Oyuncu Seçin --</option>
            @foreach (var player in Model.Players)
            {
                <option value="@player.Id" data-team-id="@player.TeamId">@player.Name</option>
            }
          </select>
          <span asp-validation-for="SubstitutionForm.PlayerInId"></span>
        </div>

        <div class="col-md-4">
          <label asp-for="SubstitutionForm.Minute" class="form-label">Dakika (Minute)</label>
          <input asp-for="SubstitutionForm.Minute" class="form-control" placeholder="Örn: 68" min="1" max="130">
          <span asp-validation-for="SubstitutionForm.Minute"></span>
        </div>
      </div>

      <div class="d-flex justify-content-end mt-5">
        <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-left-right me-2"></i> Değişikliği Kaydet</button>
      </div>
    </form>
  </div>
</div>

<partial name="_ValidationScriptsPartial" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const matchSelect = document.getElementById('matchSelect');
const teamSelect = document.getElementById('teamSelect');
const playerSelect = document.getElementById('playerSelect');
const substitutionMatchSelect = document.getElementById('substitutionMatchSelect');
const substitutionTeamSelect = document.getElementById('substitutionTeamSelect');
const playerOutSelect = document.getElementById('playerOutSelect');
const playerInSelect = document.getElementById('playerInSelect');

function resetOptions(selectElement, placeholder) {
  const firstOption = document.createElement('option');
  firstOption.value = '';
  firstOption.textContent = placeholder;
  selectElement.innerHTML = '';
  selectElement.appendChild(firstOption);
}

function populateTeamOptions() {
  const selectedMatch = matchSelect.options[matchSelect.selectedIndex];
  const selectedTeamValue = teamSelect.dataset.currentValue || teamSelect.value;
  resetOptions(teamSelect, '-- Takım Seçin --');

  if (!selectedMatch || !selectedMatch.value) {
    populatePlayerOptions();
    return;
  }

  const allowedTeamIds = [
    selectedMatch.dataset.homeTeamId,
    selectedMatch.dataset.awayTeamId
  ];

  Array.from(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Teams))).forEach(team => {
    if (!allowedTeamIds.includes(String(team.Id))) {
      return;
    }

    const option = document.createElement('option');
    option.value = team.Id;
    option.textContent = team.Name;

    if (String(team.Id) === String(selectedTeamValue)) {
      option.selected = true;
    }

    teamSelect.appendChild(option);
  });

  populatePlayerOptions();
}

function populatePlayerOptions() {
  const selectedTeamId = teamSelect.value;
  const selectedPlayerValue = playerSelect.dataset.currentValue || playerSelect.value;
  resetOptions(playerSelect, '-- Oyuncu Seçin --');

  if (!selectedTeamId) {
    return;
  }

  Array.from(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Players))).forEach(player => {
    if (String(player.TeamId) !== String(selectedTeamId)) {
      return;
    }

    const option = document.createElement('option');
    option.value = player.Id;
    option.textContent = player.Name;

    if (String(player.Id) === String(selectedPlayerValue)) {
      option.selected = true;
    }

    playerSelect.appendChild(option);
  });
}

function populateSubstitutionTeamOptions() {
  const selectedMatch = substitutionMatchSelect.options[substitutionMatchSelect.selectedIndex];
  const selectedTeamValue = substitutionTeamSelect.dataset.currentValue || substitutionTeamSelect.value;
  resetOptions(substitutionTeamSelect, '-- Takım Seçin --');

  if (!selectedMatch || !selectedMatch.value) {
    populateSubstitutionPlayerOptions();
    return;
  }

  const allowedTeamIds = [
    selectedMatch.dataset.homeTeamId,
    selectedMatch.dataset.awayTeamId
  ];

  Array.from(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Teams))).forEach(team => {
    if (!allowedTeamIds.includes(String(team.Id))) {
      return;
    }

    const option = document.createElement('option');
    option.value = team.Id;
    option.textContent = team.Name;

    if (String(team.Id) === String(selectedTeamValue)) {
      option.selected = true;
    }

    substitutionTeamSelect.appendChild(option);
  });

  populateSubstitutionPlayerOptions();
}

function populateSubstitutionPlayerOptions() {
  const selectedTeamId = substitutionTeamSelect.value;
  const selectedPlayerOutValue = playerOutSelect.dataset.currentValue || playerOutSelect.value;
  const selectedPlayerInValue = playerInSelect.dataset.currentValue || playerInSelect.value;

  resetOptions(playerOutSelect, '-- Oyuncu Seçin --');
  resetOptions(playerInSelect, '-- Oyuncu Seçin --');

  if (!selectedTeamId) {
    return;
  }

  Array.from(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Players))).forEach(player => {
    if (String(player.TeamId) !== String(selectedTeamId)) {
      return;
    }

    const playerOutOption = document.createElement('option');
    playerOutOption.value = player.Id;
    playerOutOption.textContent = player.Name;

    if (String(player.Id) === String(selectedPlayerOutValue)) {
      playerOutOption.selected = true;
    }

    playerOutSelect.appendChild(playerOutOption);

    const playerInOption = document.createElement('option');
    playerInOption.value = player.Id;
    playerInOption.textContent = player.Name;

    if (String(player.Id) === String(selectedPlayerInValue)) {
      playerInOption.selected = true;
    }

    playerInSelect.appendChild(playerInOption);
  });
}

teamSelect.dataset.currentValue = '@Model.Form.TeamId';
playerSelect.dataset.currentValue = '@Model.Form.PlayerId';
substitutionTeamSelect.dataset.currentValue = '@Model.SubstitutionForm.TeamId';
playerOutSelect.dataset.currentValue = '@Model.SubstitutionForm.PlayerOutId';
playerInSelect.dataset.currentValue = '@Model.SubstitutionForm.PlayerInId';

matchSelect.addEventListener('change', () => {
  teamSelect.dataset.currentValue = '';
  playerSelect.dataset.currentValue = '';
  populateTeamOptions();
});

teamSelect.addEventListener('change', () => {
  playerSelect.dataset.currentValue = '';
  populatePlayerOptions();
});

substitutionMatchSelect.addEventListener('change', () => {
  substitutionTeamSelect.dataset.currentValue = '';
  playerOutSelect.dataset.currentValue = '';
  playerInSelect.dataset.currentValue = '';
  populateSubstitutionTeamOptions();
});

substitutionTeamSelect.addEventListener('change', () => {
  playerOutSelect.dataset.currentValue = '';
  playerInSelect.dataset.currentValue = '';
  populateSubstitutionPlayerOptions();
});

populateTeamOptions();
populateSubstitutionTeamOptions();
</script>
</body>
</html>

icons{display:flex;align-items:center;gap:5px}.ico-btn{width:36px;height:36px;background:var(--card);border:1px solid var(--border);border-radius:var(--r1);color:var(--t2);display:flex;align-items:center;justify-content:center;font-size:14px;transition:var(--tr)}.ico-btn:hover{background:var(--elevated);color:var(--t1);border-color:var(--blue)}.tog{background:var(--card);border:1px solid var(--border);border-radius:var(--r1);padding:7px 9px;color:var(--t1);cursor:pointer;line-height:1}.mob-menu{max-height:0;overflow:hidden;transition:max-height .3s ease}.mob-menu.open{max-height:320px}.mob-menu .nl{padding:14px 0;border-bottom:1px solid var(--border);display:block}.wrap{max-width:1120px;margin:0 auto;padding:0 20px}.pg-head{background:linear-gradient(135deg,var(--bg2),var(--card));border-bottom:1px solid var(--border);padding:32px 0 24px;position:relative;overflow:hidden}.pg-head::before{content:'';position:absolute;top:-40%;right:-5%;width:380px;height:380px;background:radial-gradient(circle,rgba(41,121,255,.05) 0%,transparent 70%);pointer-events:none}.pg-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(255,214,0,.09);border:1px solid rgba(255,214,0,.22);border-radius:20px;padding:4px 12px;font-family:var(--fd);font-size:11px;font-weight:700;letter-spacing:1px;color:var(--gold);text-transform:uppercase;margin-bottom:10px}.pg-title{font-family:var(--fd);font-size:clamp(26px,5vw,42px);font-weight:900;letter-spacing:.5px;line-height:1}.pg-sub{font-size:13px;color:var(--t2);margin-top:6px}.week-nav{display:flex;align-items:center;gap:10px;margin-top:16px}.wn-btn{display:flex;align-items:center;gap:6px;background:var(--card);border:1px solid var(--border);border-radius:var(--r1);padding:8px 14px;font-family:var(--fd);font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--t2);cursor:pointer;transition:var(--tr)}.wn-btn:hover{background:var(--elevated);color:var(--t1);border-color:var(--blue)}.wn-cur{font-family:var(--fd);font-size:16px;font-weight:800;color:var(--t1);background:var(--card);border:1px solid var(--border);border-radius:var(--r1);padding:8px 20px;letter-spacing:.5px}.countdown-strip{display:flex;align-items:center;justify-content:center;gap:6px;background:rgba(41,121,255,.06);border:1px solid rgba(41,121,255,.15);border-radius:var(--r2);padding:12px 20px;margin:24px 0 0;flex-wrap:wrap}.cd-label{font-family:var(--fd);font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--t3)}.cd-box{background:var(--elevated);border-radius:var(--r1);padding:6px 14px;text-align:center}.cd-num{font-family:var(--fd);font-size:22px;font-weight:900;color:var(--blue);line-height:1}.cd-unit{font-size:9px;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-top:2px}.cd-sep{font-family:var(--fd);font-size:22px;font-weight:900;color:var(--t3)}.content{padding:28px 0 56px}.day-group{margin-bottom:28px}.day-header{display:flex;align-items:center;gap:12px;margin-bottom:12px}.day-title{font-family:var(--fd);font-size:13px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--t2)}.day-date{font-family:var(--fd);font-size:12px;color:var(--t3);letter-spacing:1px}.day-line{flex:1;height:1px;background:var(--border)}.day-badge{font-family:var(--fd);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:3px 10px;border-radius:8px;white-space:nowrap}.db-today{background:rgba(0,230,118,.1);border:1px solid rgba(0,230,118,.2);color:var(--green)}.db-tomorrow{background:rgba(41,121,255,.1);border:1px solid rgba(41,121,255,.2);color:var(--blue)}.db-sun{background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.18);color:var(--gold)}.fx-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:0;margin-bottom:8px;overflow:hidden;transition:var(--tr);position:relative}.fx-card:hover{background:var(--card2);border-color:rgba(41,121,255,.3);transform:translateY(-1px);box-shadow:0 6px 24px rgba(0,0,0,.4)}.fx-card.top-match{border-color:rgba(255,214,0,.22);background:linear-gradient(135deg,var(--card),rgba(255,214,0,.03))}.fx-card.top-match:hover{border-color:rgba(255,214,0,.4)}.fx-top-badge{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),transparent)}.fx-inner{display:flex;align-items:center;padding:14px 18px;gap:0}.fx-time-col{width:72px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:4px}.fx-time{font-family:var(--fd);font-size:16px;font-weight:700;color:var(--t2)}.fx-day-label{font-family:var(--fd);font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--t3)}.fx-divider{width:1px;height:44px;background:var(--border);margin:0 16px;flex-shrink:0}.fx-teams{flex:1;min-width:0;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:8px}.fx-team-home{display:flex;align-items:center;gap:10px;justify-content:flex-end}.fx-team-away{display:flex;align-items:center;gap:10px}.fx-name{font-family:var(--fd);font-size:16px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.fx-name.home{text-align:right}.fx-logo{width:28px;height:28px;border-radius:50%;background:var(--elevated);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:9px;font-weight:800;color:var(--t2);overflow:hidden;flex-shrink:0}.fx-logo img{width:100%;height:100%;object-fit:contain;padding:3px}.vs-block{display:flex;flex-direction:column;align-items:center;gap:2px;flex-shrink:0}.vs-text{font-family:var(--fd);font-size:13px;font-weight:800;color:var(--t3)}.fx-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;margin-left:14px;flex-shrink:0}.fx-stadium{font-size:11px;color:var(--t3);text-align:right;max-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.notify-btn{display:inline-flex;align-items:center;gap:5px;background:rgba(41,121,255,.08);border:1px solid rgba(41,121,255,.2);color:var(--blue);border-radius:var(--r1);padding:5px 10px;font-family:var(--fd);font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;cursor:pointer;transition:var(--tr)}.notify-btn:hover{background:rgba(41,121,255,.18);color:var(--blue)}.notify-btn.active{background:rgba(0,230,118,.1);border-color:rgba(0,230,118,.3);color:var(--green)}.top-match-tag{font-family:var(--fd);font-size:9px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.2);padding:2px 8px;border-radius:7px}.h2h-strip{background:var(--bg2);border-top:1px solid var(--border);padding:8px 18px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}.h2h-label{font-family:var(--fd);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--t3);white-space:nowrap}.h2h-pills{display:flex;gap:4px}.h2h-p{width:22px;height:22px;border-radius:5px;font-family:var(--fd);font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center}.h2h-w{background:rgba(0,230,118,.15);color:var(--green)}.h2h-d{background:rgba(123,150,196,.12);color:var(--t2)}.h2h-l{background:rgba(255,23,68,.12);color:var(--live)}.h2h-avg{font-family:var(--fd);font-size:11px;color:var(--t3);margin-left:auto}.kp-strip{background:var(--bg2);border-top:1px solid var(--border);padding:8px 18px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}.kp-label{font-family:var(--fd);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--t3);white-space:nowrap}.kp-tag{display:inline-flex;align-items:center;gap:5px;background:var(--elevated);border:1px solid var(--border);border-radius:7px;padding:4px 9px;font-family:var(--fd);font-size:11px;font-weight:700;color:var(--t2)}.kp-tag i{font-size:10px;color:var(--green)}.week-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}.ws-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r2);padding:16px;text-align:center}.ws-num{font-family:var(--fd);font-size:26px;font-weight:900;line-height:1}.ws-lbl{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-top:4px;font-weight:600}.ft{background:var(--bg2);border-top:1px solid var(--border);padding:44px 0 22px;margin-top:0}.ft-brand{font-family:var(--fd);font-size:20px;font-weight:800;margin-bottom:8px}.ft-brand span{color:var(--green)}.ft-desc{font-size:12px;color:var(--t3);line-height:1.7;max-width:240px}.ft-h{font-family:var(--fd);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--t2);margin-bottom:14px}.ft-ul{list-style:none;padding:0}.ft-ul li{margin-bottom:7px}.ft-ul a{color:var(--t3);font-size:12px;transition:var(--tr)}.ft-ul a:hover{color:var(--t1)}.si-row{display:flex;gap:7px;margin-top:14px}.si{width:34px;height:34px;background:var(--card);border:1px solid var(--border);border-radius:var(--r1);display:flex;align-items:center;justify-content:center;color:var(--t3);transition:var(--tr);font-size:13px}.si:hover{background:var(--elevated);color:var(--green);border-color:var(--green)}.ft-bot{border-top:1px solid var(--border);padding-top:18px;margin-top:32px;font-size:11px;color:var(--t3);display:flex;justify-content:space-between;flex-wrap:wrap;gap:6px}@@media(max-width:768px){.fx-right .fx-stadium{display:none}.week-summary{grid-template-columns:repeat(2,1fr)}.kp-strip,.h2h-strip{display:none}.fx-name{font-size:13px}.fx-time{font-size:14px}}@@media(max-width:500px){.fx-teams{gap:4px}.fx-name{font-size:12px}.fx-logo{width:22px;height:22px}.week-summary{grid-template-columns:repeat(2,1fr);gap:8px}.ws-num{font-size:20px}.notify-btn span{display:none}.fx-right{margin-left:8px}}
</style>
</head>
<body>
<nav class="nb">
  <div class="nb-inner">
    <a asp-action="Index" asp-controller="Home" class="brand"><div class="brand-ico">⚽</div><span class="brand-txt">Goal<span>Zone</span></span></a>
    <div class="nav-links d-none d-lg-flex"><a asp-action="Index" asp-controller="Home" class="nl">Ana Sayfa</a><a asp-action="Index" asp-controller="Home" asp-fragment="live-section" class="nl">Canlı Skorlar</a><a asp-action="Fixtures" asp-controller="Home" asp-route-weekNumber="@Model.WeekNumber" class="nl active">Fikstür</a><a asp-action="Standings" asp-controller="Home" class="nl">Puan Durumu</a></div>
    <div class="nb-icons"><a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-search"></i></a><a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-bell"></i></a><a href="#" class="ico-btn"><i class="bi bi-person"></i></a><button class="tog d-lg-none" id="tog"><i class="bi bi-list"></i></button></div>
  </div>
  <div class="mob-menu" id="mobMenu"><div class="wrap"><a asp-action="Index" asp-controller="Home" class="nl d-block">Ana Sayfa</a><a asp-action="Index" asp-controller="Home" asp-fragment="live-section" class="nl d-block">Canlı Skorlar</a><a asp-action="Fixtures" asp-controller="Home" asp-route-weekNumber="@Model.WeekNumber" class="nl d-block active">Fikstür</a><a asp-action="Standings" asp-controller="Home" class="nl d-block">Puan Durumu</a></div></div>
</nav>
<section class="pg-head"><div class="wrap"><div class="row align-items-end"><div class="col-lg-7"><div class="pg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div><h1 class="pg-title">Hafta <span style="color:var(--blue)">@Model.WeekNumber</span> Fikstürü</h1><p class="pg-sub">@Model.FullStartDate - @Model.FullEndDate &nbsp;·&nbsp; @Model.MatchCount Maç</p><div class="week-nav"><a asp-action="Fixtures" asp-controller="Home" asp-route-weekNumber="@Model.PreviousWeekNumber" class="wn-btn"><i class="bi bi-chevron-left"></i> <span>Hafta @Model.PreviousWeekNumber</span></a><div class="wn-cur">Hafta @Model.WeekNumber</div><a asp-action="Fixtures" asp-controller="Home" asp-route-weekNumber="@Model.NextWeekNumber" class="wn-btn"><span>Hafta @Model.NextWeekNumber</span> <i class="bi bi-chevron-right"></i></a></div></div><div class="col-lg-5 mt-3 mt-lg-0"><div class="countdown-strip" data-target="@countdownTarget"><span class="cd-label">İlk Maça</span><div class="cd-box"><div class="cd-num" id="cd-d">00</div><div class="cd-unit">Gün</div></div><span class="cd-sep">:</span><div class="cd-box"><div class="cd-num" id="cd-h">00</div><div class="cd-unit">Saat</div></div><span class="cd-sep">:</span><div class="cd-box"><div class="cd-num" id="cd-m">00</div><div class="cd-unit">Dakika</div></div><span class="cd-sep">:</span><div class="cd-box"><div class="cd-num" id="cd-s">00</div><div class="cd-unit">Saniye</div></div></div></div></div></div></section>
<main><div class="wrap"><div class="content"><div class="week-summary"><div class="ws-card"><div class="ws-num" style="color:var(--blue)">@Model.MatchCount</div><div class="ws-lbl">Toplam Maç</div></div><div class="ws-card"><div class="ws-num" style="color:var(--gold)">@Model.TopMatchCount</div><div class="ws-lbl">Top Match</div></div><div class="ws-card"><div class="ws-num" style="color:var(--green)">@Model.StartMatchDay-@Model.EndMatchDay</div><div class="ws-lbl">Maç Günleri</div></div><div class="ws-card"><div class="ws-num" style="color:var(--live)">@Model.StartDate.ToString("dd", tr)</div><div class="ws-lbl">@Model.StartDate.ToString("MMMM yyyy", tr)</div></div></div>
@foreach (var dayGroup in Model.DayGroups)
{
    <div class="day-group">
      <div class="day-header"><span class="day-title">@dayGroup.DayName</span><span class="day-date">@dayGroup.Date.ToString("dd MMMM yyyy", tr)</span><div class="day-line"></div><span class="day-badge @GetDayBadgeClass(dayGroup.Date)">@GetDayBadgeText(dayGroup.Date, dayGroup.MatchCount)</span></div>
      @foreach (var item in dayGroup.Matches)
      {
          <div class="fx-card @(item.IsFeaturedMatch ? "top-match" : "")">
            @if (item.IsFeaturedMatch)
            {
                <div class="fx-top-badge"></div>
            }
            <div class="fx-inner">
              <div class="fx-time-col">
                <div class="fx-time">@item.MatchTime</div>
                @if (item.IsFeaturedMatch)
                {
                    <div class="top-match-tag">★ TOP</div>
                }
                else
                {
                    <div class="fx-day-label">@GetDayLabel(item.MatchDate)</div>
                }
              </div>
              <div class="fx-divider"></div>
              <div class="fx-teams">
                <div class="fx-team-home"><span class="fx-name home">@item.HomeTeamName</span><div class="fx-logo">@if (!string.IsNullOrWhiteSpace(item.HomeTeamLogoUrl)) { <img src="@item.HomeTeamLogoUrl" alt="@item.HomeTeamName" /> } else { <span>@item.HomeTeamName[..Math.Min(3, item.HomeTeamName.Length)].ToUpper(tr)</span> }</div></div>
                <div class="vs-block"><span class="vs-text">VS</span></div>
                <div class="fx-team-away"><div class="fx-logo">@if (!string.IsNullOrWhiteSpace(item.AwayTeamLogoUrl)) { <img src="@item.AwayTeamLogoUrl" alt="@item.AwayTeamName" /> } else { <span>@item.AwayTeamName[..Math.Min(3, item.AwayTeamName.Length)].ToUpper(tr)</span> }</div><span class="fx-name">@item.AwayTeamName</span></div>
              </div>
              <div class="fx-right"><span class="fx-stadium"><i class="bi bi-geo-alt" style="font-size:10px;margin-right:3px"></i>@item.StadiumName</span><button type="button" class="notify-btn" onclick="toggleNotify(this)"><i class="bi bi-bell"></i> <span>Bildir</span></button></div>
            </div>
            @if (item.HomeLast5Matches.Any() || item.AwayLast5Matches.Any())
            {
                <div class="h2h-strip"><span class="h2h-label">Son 5 Form</span><div class="h2h-pills">@foreach (var result in item.HomeLast5Matches) { <div class="h2h-p @GetMatchResultClass(result)">@result</div> }</div><span class="h2h-avg">Ev sahibi formu</span></div>
                <div class="kp-strip"><span class="kp-label">Deplasman Formu</span>@foreach (var result in item.AwayLast5Matches) { <span class="kp-tag"><i class="bi bi-lightning-fill"></i>@result</span> }</div>
            }
          </div>
      }
    </div>
}
</div></div></main>
